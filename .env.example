# Copy this file to .env and fill in real values. Never commit .env itself.
#
# This file is for local dev only. For production (Vercel + Neon), every
# var below gets its own real value entered directly into Vercel's
# dashboard — see docs/deployment.md (Sprint-039) for the full list and
# where each value comes from.

# Sprint-035 (RFC-0003 §8h addendum): local dev Postgres, run via
# `docker compose up -d` (see docker-compose.yml at the repo root) — this
# exact value matches that file's port/user/password/database. Replaces
# `npx prisma dev --detach`: that Postgres turned out to be PGlite under the
# hood, which doesn't support the `pgvector` extension Sprint-035 needs.
# Port 54330, not 5432/51214 — see docker-compose.yml's own comment on
# Windows' dynamic Hyper-V port-exclusion ranges if this ever needs to
# change again.
DATABASE_URL="postgres://postgres:postgres@localhost:54330/atlas_dev?sslmode=disable&connection_limit=10&connect_timeout=0&max_idle_connection_lifetime=0&pool_timeout=0&socket_timeout=0"

# Sprint-024: test database target — a dedicated, real Postgres instance
# used only by the automated test suite (`npm test`), fully separate from
# the dev database above. Booted, schema-applied, and torn down
# automatically for every `npm test` run (vitest.global-setup.ts) via
# Docker (scripts/test-postgres.mjs) — Sprint-035 (RFC-0003 §8h addendum)
# moved this off the `embedded-postgres` npm package for the same
# `pgvector`-support reason as the dev database above; the Docker daemon
# GitHub Actions' `ubuntu-latest` runners already have makes this work
# unchanged in CI, no new `services:` block needed. `npm run test:db:push`
# is a manual convenience only (confirms the schema applies cleanly); it is
# not required before `npm test`.
TEST_DATABASE_URL="postgres://postgres:postgres@localhost:54329/atlas_test?sslmode=disable"

# Auth.js session secret. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Google Calendar Provider (Sprint-015, read-only) — see docs/google-calendar-setup.md
# for how to create these in the Google Cloud console.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/providers/google-calendar/callback

# Encrypts persisted Google Calendar OAuth tokens at rest (AES-256-GCM). Must
# be a base64-encoded 32-byte key. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ATLAS_TOKEN_ENCRYPTION_KEY=

# Sprint-034: real-world information retrieval (RFC-0003 §8g). Get a key
# at https://console.anthropic.com/settings/keys — this is a paid API,
# unlike every other Provider in this project so far.
ANTHROPIC_API_KEY=

# Sprint-035: Document semantic search (RFC-0003 §8h). Get a key at
# https://dash.voyageai.com — paid API, separate from ANTHROPIC_API_KEY
# (Anthropic has no embeddings endpoint; Voyage AI is Anthropic's own
# recommended embeddings provider).
VOYAGE_API_KEY=
